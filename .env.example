# =============================================================================
# AI Tutor Backend - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# --- Application ---
APP_VERSION=0.1.0
SERVER_PORT=8080
CORS_ALLOWED_ORIGINS=*

# --- Database ---
AITUTOR_DB_URL=jdbc:postgresql://localhost:5432/aitutor
AITUTOR_DB_USER=aitutor
AITUTOR_DB_PASSWORD=aitutor_secret
AITUTOR_DB_DRIVER=org.postgresql.Driver
AITUTOR_DB_MAX_POOL_SIZE=10

# --- Uploads ---
AITUTOR_UPLOADS_DIR=uploads

# --- Ollama ---
AITUTOR_OLLAMA_BASE_URL=http://localhost:11434
AITUTOR_OLLAMA_EMBED_MODEL=nomic-embed-text

# --- OpenAI ---
AITUTOR_OPENAI_BASE_URL=https://api.openai.com/v1
AITUTOR_OPENAI_EMBED_MODEL=text-embedding-3-small

# --- Gemini ---
AITUTOR_GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
AITUTOR_GEMINI_EMBED_MODEL=text-embedding-004

# --- Default LLM (used when X-LLM-Provider / X-Model headers are absent) ---
AITUTOR_DEFAULT_PROVIDER=openai
AITUTOR_DEFAULT_MODEL=gpt-4o

# --- Chunking ---
AITUTOR_CHUNKING_MAX_TOKENS=512
AITUTOR_CHUNKING_OVERLAP_PERCENT=15

# --- RAG ---
AITUTOR_RAG_TOP_K=10
AITUTOR_RAG_MAX_CONTEXT_TOKENS=3000

# --- Chat ---
AITUTOR_CHAT_MAX_HISTORY=10
AITUTOR_CHAT_SNIPPET_LENGTH=200
AITUTOR_CHAT_TITLE_LENGTH=100
